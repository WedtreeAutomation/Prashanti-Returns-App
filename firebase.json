{
  "functions": {
    "source": "functions",
    "ignore": [
      "venv",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "prashanti_returns_api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}